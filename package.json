{
  "name": "helvetic-freight-desktop",
  "version": "1.1.38",
  "description": "Desktop-Wrapper fuer Helvetic Freight Clean, damit das Spiel als Windows-EXE mit app-eigenem Speicher laeuft.",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable",
    "build:win-installer": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ch.helveticfreight.clean.desktop",
    "productName": "Helvetic Freight Clean",
    "files": [
      "Helvetic_Freight_v1.1.38_CleanApp.html",
      "Helvetic_Freight_v1.1.38_CleanApp.css",
      "scripts/**/*",
      "desktop/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
